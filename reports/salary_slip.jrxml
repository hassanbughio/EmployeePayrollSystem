<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="salary_slip" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="emp_id" class="java.lang.Integer"/>
    <parameter name="emp_name" class="java.lang.String"/>
    <parameter name="month" class="java.lang.Integer"/>
    <parameter name="year" class="java.lang.Integer"/>
    <parameter name="basic_salary" class="java.lang.Double"/>
    <parameter name="bonus" class="java.lang.Double"/>
    <parameter name="tax" class="java.lang.Double"/>
    <parameter name="deductions" class="java.lang.Double"/>
    <parameter name="net_salary" class="java.lang.Double"/>
    <parameter name="emp_photo" class="java.lang.String"/>

    <title>
        <band height="130" splitType="Stretch">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="100" backcolor="#0F3460" forecolor="#0F3460"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <rectangle>
                <reportElement x="0" y="100" width="555" height="5" backcolor="#E94560" forecolor="#E94560"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="10" y="10" width="400" height="40" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="22" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Employee Payroll System]]></text>
            </staticText>

            <staticText>
                <reportElement x="10" y="50" width="400" height="25" forecolor="#AAAAFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="11" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Official Salary Slip Document]]></text>
            </staticText>

            <staticText>
                <reportElement x="370" y="15" width="170" height="30" forecolor="#E94560"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="16" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[SALARY SLIP]]></text>
            </staticText>

            <image onErrorType="Blank" scaleImage="RetainShape">
                <reportElement x="440" y="15" width="105" height="70"/>
                <imageExpression><![CDATA[$P{emp_photo}]]></imageExpression>
            </image>

            <staticText>
                <reportElement x="10" y="110" width="100" height="18" forecolor="#555555"/>
                <textElement>
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[PAY PERIOD:]]></text>
            </staticText>
            <textField>
                <reportElement x="110" y="110" width="200" height="18" forecolor="#0F3460"/>
                <textElement>
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Month " + $P{month} + " / " + $P{year}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <summary>
        <band height="580" splitType="Stretch">

            <!-- EMPLOYEE INFO -->
            <staticText>
                <reportElement x="0" y="10" width="555" height="22" backcolor="#F0F2F5" forecolor="#0F3460"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  EMPLOYEE INFORMATION]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="32" width="555" height="1" forecolor="#0F3460"/>
            </line>

            <staticText>
                <reportElement x="0" y="40" width="150" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Employee ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="40" width="10" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[:]]></text>
            </staticText>
            <textField>
                <reportElement x="165" y="40" width="200" height="22" forecolor="#1a1a2e"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{emp_id}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="68" width="150" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Employee Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="68" width="10" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[:]]></text>
            </staticText>
            <textField>
                <reportElement x="165" y="68" width="200" height="22" forecolor="#1a1a2e"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{emp_name}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="96" width="150" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Pay Month / Year]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="96" width="10" height="22" forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[:]]></text>
            </staticText>
            <textField>
                <reportElement x="165" y="96" width="200" height="22" forecolor="#1a1a2e"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{month} + " / " + $P{year}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="128" width="555" height="1" forecolor="#DDDDDD"/>
            </line>

            <!-- EARNINGS -->
            <staticText>
                <reportElement x="0" y="138" width="555" height="22" backcolor="#E8F4E8" forecolor="#2E7D32"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  EARNINGS]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="163" width="350" height="20" backcolor="#F5F5F5" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Description]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="163" width="205" height="20" backcolor="#F5F5F5" forecolor="#333333"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Amount (PKR)  ]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="185" width="350" height="25" forecolor="#444444"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Basic Salary]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="185" width="205" height="25" forecolor="#2E7D32"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{basic_salary}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="213" width="350" height="25" forecolor="#444444"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Bonus / Allowance]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="213" width="205" height="25" forecolor="#2E7D32"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{bonus}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="240" width="555" height="25" backcolor="#E8F4E8" forecolor="#E8F4E8"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="240" width="350" height="25" forecolor="#2E7D32"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  GROSS EARNINGS]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="240" width="205" height="25" forecolor="#2E7D32"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{basic_salary} + $P{bonus}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="272" width="555" height="1" forecolor="#DDDDDD"/>
            </line>

            <!-- DEDUCTIONS -->
            <staticText>
                <reportElement x="0" y="280" width="555" height="22" backcolor="#FDECEA" forecolor="#C62828"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  DEDUCTIONS]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="305" width="350" height="20" backcolor="#F5F5F5" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Description]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="305" width="205" height="20" backcolor="#F5F5F5" forecolor="#333333"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Amount (PKR)  ]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="327" width="350" height="25" forecolor="#444444"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Income Tax]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="327" width="205" height="25" forecolor="#C62828"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{tax}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="355" width="350" height="25" forecolor="#444444"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Other Deductions]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="355" width="205" height="25" forecolor="#C62828"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{deductions}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="382" width="555" height="25" backcolor="#FDECEA" forecolor="#FDECEA"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="382" width="350" height="25" forecolor="#C62828"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  TOTAL DEDUCTIONS]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="382" width="205" height="25" forecolor="#C62828"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{tax} + $P{deductions}]]></textFieldExpression>
            </textField>

            <!-- NET SALARY -->
            <rectangle>
                <reportElement x="0" y="425" width="555" height="55" backcolor="#0F3460" forecolor="#0F3460"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="425" width="300" height="55" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="14" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[NET SALARY PAYABLE]]></text>
            </staticText>
            <textField pattern="PKR #,##0.00">
                <reportElement x="310" y="425" width="235" height="55" forecolor="#E94560"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="16" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{net_salary}]]></textFieldExpression>
            </textField>

            <!-- FOOTER -->
            <line>
                <reportElement x="0" y="500" width="555" height="1" forecolor="#DDDDDD"/>
            </line>
            <staticText>
                <reportElement x="0" y="508" width="555" height="20" forecolor="#999999"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[This is a computer generated salary slip and does not require a signature.]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="530" width="555" height="20" forecolor="#999999"/>
                <textElement textAlignment="Center">
                    <font size="8" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Employee Payroll Management System — Confidential Document]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="555" width="555" height="4" backcolor="#E94560" forecolor="#E94560"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

        </band>
    </summary>
</jasperReport>
