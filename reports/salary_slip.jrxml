<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="salary_slip" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!-- Parameters -->
    <parameter name="emp_id" class="java.lang.Integer"/>
    <parameter name="emp_name" class="java.lang.String"/>
    <parameter name="month" class="java.lang.Integer"/>
    <parameter name="year" class="java.lang.Integer"/>
    <parameter name="basic_salary" class="java.lang.Double"/>
    <parameter name="bonus" class="java.lang.Double"/>
    <parameter name="tax" class="java.lang.Double"/>
    <parameter name="deductions" class="java.lang.Double"/>
    <parameter name="net_salary" class="java.lang.Double"/>

    <!-- Title -->
    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[Employee Payroll System]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14"/>
                </textElement>
                <text><![CDATA[Salary Slip]]></text>
            </staticText>
        </band>
    </title>

    <!-- Detail -->
    <summary>
        <band height="300">
            <!-- Emp ID -->
            <staticText>
                <reportElement x="0" y="10" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Employee ID:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="10" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{emp_id}]]></textFieldExpression>
            </textField>

            <!-- Emp Name -->
            <staticText>
                <reportElement x="0" y="40" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Employee Name:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="40" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{emp_name}]]></textFieldExpression>
            </textField>

            <!-- Month/Year -->
            <staticText>
                <reportElement x="0" y="70" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Month/Year:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="70" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{month} + "/" + $P{year}]]></textFieldExpression>
            </textField>

            <!-- Basic Salary -->
            <staticText>
                <reportElement x="0" y="110" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Basic Salary:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="110" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{basic_salary}]]></textFieldExpression>
            </textField>

            <!-- Bonus -->
            <staticText>
                <reportElement x="0" y="140" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Bonus:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="140" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{bonus}]]></textFieldExpression>
            </textField>

            <!-- Tax -->
            <staticText>
                <reportElement x="0" y="170" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Tax:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="170" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{tax}]]></textFieldExpression>
            </textField>

            <!-- Deductions -->
            <staticText>
                <reportElement x="0" y="200" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Deductions:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="200" width="355" height="25"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{deductions}]]></textFieldExpression>
            </textField>

            <!-- Net Salary -->
            <staticText>
                <reportElement x="0" y="240" width="200" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Net Salary:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="240" width="355" height="25"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{net_salary}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>